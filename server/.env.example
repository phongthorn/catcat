# Copy to server/.env (gitignored). Loaded by the Rust server at startup.

# Optional: explicit path to adb.exe if it isn't on PATH.
# ADB_PATH=C:\path\to\adb.exe

# Shared secret gating every route on the headless server. MUST match
# CATCAT_WS_SECRET in docker/.env so nginx (/ws) and PHP (/api) are accepted.
# Leave unset only for local dev (the X-Catcat-Auth check is then disabled).
CATCAT_WS_SECRET=change-me-ws-secret
