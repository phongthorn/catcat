# Copy to .env and adjust. Used by docker-compose.yml for the MySQL service.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=catcat
MYSQL_USER=catcat
MYSQL_PASSWORD=change-me-catcat

# Shared secret the nginx proxy + PHP send to the headless Rust server in the
# X-Catcat-Auth header. Set the SAME value in the Rust host's server/.env
# (CATCAT_WS_SECRET=...). Use a long random string, e.g. `openssl rand -hex 32`.
CATCAT_WS_SECRET=change-me-ws-secret

# Full path to the cloudflared tunnel credentials JSON file.
# Windows example: C:\Users\YourName\.cloudflared\<tunnel-uuid>.json
CLOUDFLARED_CREDS_FILE=C:\Users\MMC-PHONG\.cloudflared\2f22f096-0106-41ac-b02f-88ce0eaa94b8.json
